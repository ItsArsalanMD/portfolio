---
---

<section id="about" class="py-24 relative overflow-hidden bg-bg-secondary/40">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="mb-12 reveal">
      <span class="font-mono text-sm text-accent-cyan tracking-wider block mb-2">// ABOUT ME</span>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-text-primary">
        Turning Ideas Into<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-cyan to-accent-green">Production-Grade Systems.</span>
      </h2>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Left Narrative Text (7 columns equivalent) -->
      <div class="lg:col-span-7 space-y-6 font-body text-text-secondary leading-relaxed text-base reveal stagger-1">
        <p>
          I'm a Full-Stack Web Developer with hands-on experience across the entire development lifecycle — from crafting pixel-perfect interfaces in React and TypeScript, to architecting robust APIs with ASP.NET Core and Django, to deploying containerized microservices on AWS using Docker and Terraform.
        </p>
        <p>
          Currently pursuing my MCA from Dr. Babasaheb Ambedkar Marathwada University, I combine academic foundations with real-world professional experience gained across three companies in roles from developer to team lead to DevOps engineer.
        </p>
        <p>
          I'm also actively available for freelance projects — especially web apps, SaaS products, and DevOps automation engagements.
        </p>
      </div>

      <!-- Right Stats Card (5 columns equivalent) -->
      <div class="lg:col-span-5 reveal stagger-2">
        <div class="bg-bg-surface border border-border-main rounded-xl p-8 shadow-xl relative overflow-hidden group">
          <!-- Ambient Hover Glow -->
          <div class="absolute -inset-px bg-gradient-to-r from-accent-cyan/10 to-accent-green/10 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          
          <div class="grid grid-cols-2 gap-8 relative z-10">
            <!-- Stat 1 -->
            <div class="flex flex-col space-y-1">
              <span class="font-display font-bold text-4xl md:text-5xl text-accent-cyan group-hover:scale-105 transition-transform duration-300 origin-left">2+</span>
              <span class="font-mono text-xs uppercase tracking-wider text-text-secondary">Years of Experience</span>
            </div>
            
            <!-- Stat 2 -->
            <div class="flex flex-col space-y-1">
              <span class="font-display font-bold text-4xl md:text-5xl text-accent-cyan group-hover:scale-105 transition-transform duration-300 origin-left">3</span>
              <span class="font-mono text-xs uppercase tracking-wider text-text-secondary">Companies Worked At</span>
            </div>

            <!-- Stat 3 -->
            <div class="flex flex-col space-y-1">
              <span class="font-display font-bold text-4xl md:text-5xl text-accent-cyan group-hover:scale-105 transition-transform duration-300 origin-left">5+</span>
              <span class="font-mono text-xs uppercase tracking-wider text-text-secondary">Freelance Projects</span>
            </div>

            <!-- Stat 4 -->
            <div class="flex flex-col space-y-1">
              <span class="font-display font-bold text-4xl md:text-5xl text-accent-cyan group-hover:scale-105 transition-transform duration-300 origin-left">15+</span>
              <span class="font-mono text-xs uppercase tracking-wider text-text-secondary">Tech Mastered</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
