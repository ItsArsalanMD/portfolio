---
import { skills } from '../data/skills.js';
---

<section id="skills" class="py-24 relative overflow-hidden">
  <!-- Glowing Background Effect -->
  <div class="absolute left-1/4 top-1/3 w-[500px] h-[500px] rounded-full glow-bg-green -z-10 opacity-40 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="mb-12 reveal">
      <span class="font-mono text-sm text-accent-cyan tracking-wider block mb-2">// TECH STACK</span>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-text-primary">
        Tools I Build With
      </h2>
    </div>

    <!-- Skills Category Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {skills.map((skillGroup, groupIdx) => (
        <div 
          class={`bg-bg-surface border border-border-main rounded-xl p-6 shadow-lg hover:border-accent-cyan/35 transition-colors duration-300 reveal stagger-${(groupIdx % 3) + 1}`}
        >
          <!-- Category Header -->
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl select-none" role="img" aria-label={skillGroup.category}>
              {skillGroup.icon}
            </span>
            <h3 class="font-display font-semibold text-lg text-text-primary tracking-wide">
              {skillGroup.category}
            </h3>
          </div>

          <!-- Skill Pills -->
          <div class="flex flex-wrap gap-2.5">
            {skillGroup.items.map((skill) => (
              <span 
                class="font-mono text-xs text-text-secondary bg-bg-secondary/60 border border-border-main px-3 py-1.5 rounded-full hover:border-accent-cyan hover:text-accent-cyan hover:scale-105 transition-all duration-200 select-none cursor-default"
              >
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
