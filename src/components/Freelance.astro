---
---

<section id="freelance" class="py-24 relative overflow-hidden bg-bg-primary dot-grid">
  <!-- Blurred Radial Glow -->
  <div class="absolute left-1/2 bottom-10 w-[500px] h-[500px] rounded-full glow-bg -z-10 opacity-40 pointer-events-none transform -translate-x-1/2"></div>

  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="mb-16 text-center max-w-2xl mx-auto reveal">
      <span class="font-mono text-sm text-accent-cyan tracking-wider block mb-2">// FREELANCE</span>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-text-primary mb-4">
        Available for Hire
      </h2>
      <p class="font-body text-text-secondary">
        I take on freelance projects in web development and DevOps. Here's what I can build for you.
      </p>
    </div>

    <!-- Service Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
      
      <!-- Card 1 -->
      <div class="bg-bg-surface border border-border-main rounded-xl p-8 hover:border-accent-cyan/45 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group reveal">
        <div>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-lg bg-accent-cyan/10 border border-accent-cyan/25 flex items-center justify-center text-accent-cyan mb-6 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <!-- Title & Desc -->
          <h3 class="font-display font-semibold text-xl text-text-primary mb-4">
            Full-Stack Web App Development
          </h3>
          <p class="font-body text-text-secondary text-sm md:text-base leading-relaxed mb-6">
            End-to-end web application development using React/TypeScript on the front-end and ASP.NET Core or Django on the back-end. From MVPs to production-grade systems.
          </p>
        </div>
        <!-- Tags -->
        <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border-main font-mono text-[10px] text-text-muted">
          <span>React</span><span>•</span>
          <span>TypeScript</span><span>•</span>
          <span>.NET Core</span><span>•</span>
          <span>Django</span><span>•</span>
          <span>PostgreSQL</span>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bg-bg-surface border border-border-main rounded-xl p-8 hover:border-accent-cyan/45 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group reveal stagger-1">
        <div>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-lg bg-accent-cyan/10 border border-accent-cyan/25 flex items-center justify-center text-accent-cyan mb-6 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
          </div>
          <!-- Title & Desc -->
          <h3 class="font-display font-semibold text-xl text-text-primary mb-4">
            DevOps &amp; Cloud Automation
          </h3>
          <p class="font-body text-text-secondary text-sm md:text-base leading-relaxed mb-6">
            CI/CD pipeline setup, cloud infrastructure provisioning on AWS, containerization with Docker, and configuration management with Ansible and Terraform.
          </p>
        </div>
        <!-- Tags -->
        <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border-main font-mono text-[10px] text-text-muted">
          <span>AWS</span><span>•</span>
          <span>Docker</span><span>•</span>
          <span>Terraform</span><span>•</span>
          <span>Jenkins</span><span>•</span>
          <span>GitHub Actions</span>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="bg-bg-surface border border-border-main rounded-xl p-8 hover:border-accent-cyan/45 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group reveal stagger-2">
        <div>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-lg bg-accent-cyan/10 border border-accent-cyan/25 flex items-center justify-center text-accent-cyan mb-6 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <!-- Title & Desc -->
          <h3 class="font-display font-semibold text-xl text-text-primary mb-4">
            API Design &amp; Backend Engineering
          </h3>
          <p class="font-body text-text-secondary text-sm md:text-base leading-relaxed mb-6">
            RESTful and microservices API development, database architecture, unit and integration testing, and backend performance optimization.
          </p>
        </div>
        <!-- Tags -->
        <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border-main font-mono text-[10px] text-text-muted">
          <span>ASP.NET Core</span><span>•</span>
          <span>Django REST</span><span>•</span>
          <span>PostgreSQL</span><span>•</span>
          <span>xUnit</span><span>•</span>
          <span>PyTest</span>
        </div>
      </div>

    </div>

    <!-- "How I Work" Process Flow -->
    <div class="mb-24">
      <h3 class="font-display font-semibold text-2xl text-text-primary text-center mb-16 reveal">
        How I Work
      </h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 relative z-10">
        
        <!-- Step 1 -->
        <div class="relative flex flex-col items-center text-center reveal">
          <!-- Connector Line (Only for desktop) -->
          <div class="hidden lg:block absolute top-6 left-[60%] w-[80%] h-[1px] border-t-2 border-dashed border-accent-cyan/25 -z-10"></div>
          
          <div class="w-12 h-12 rounded-full bg-bg-secondary border-2 border-accent-cyan flex items-center justify-center font-display font-bold text-accent-cyan mb-4 shadow-lg shadow-accent-cyan/15 select-none">
            01
          </div>
          <h4 class="font-display font-semibold text-text-primary mb-2">Discovery</h4>
          <p class="font-body text-text-secondary text-sm leading-relaxed px-4">
            You share your idea, goals, and requirements
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative flex flex-col items-center text-center reveal stagger-1">
          <!-- Connector Line (Only for desktop) -->
          <div class="hidden lg:block absolute top-6 left-[60%] w-[80%] h-[1px] border-t-2 border-dashed border-accent-cyan/25 -z-10"></div>
          
          <div class="w-12 h-12 rounded-full bg-bg-secondary border-2 border-accent-cyan flex items-center justify-center font-display font-bold text-accent-cyan mb-4 shadow-lg shadow-accent-cyan/15 select-none">
            02
          </div>
          <h4 class="font-display font-semibold text-text-primary mb-2">Proposal</h4>
          <p class="font-body text-text-secondary text-sm leading-relaxed px-4">
            I scope the work, timeline, and cost
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative flex flex-col items-center text-center reveal stagger-2">
          <!-- Connector Line (Only for desktop) -->
          <div class="hidden lg:block absolute top-6 left-[60%] w-[80%] h-[1px] border-t-2 border-dashed border-accent-cyan/25 -z-10"></div>
          
          <div class="w-12 h-12 rounded-full bg-bg-secondary border-2 border-accent-cyan flex items-center justify-center font-display font-bold text-accent-cyan mb-4 shadow-lg shadow-accent-cyan/15 select-none">
            03
          </div>
          <h4 class="font-display font-semibold text-text-primary mb-2">Development</h4>
          <p class="font-body text-text-secondary text-sm leading-relaxed px-4">
            I build iteratively with regular updates
          </p>
        </div>

        <!-- Step 4 -->
        <div class="relative flex flex-col items-center text-center reveal stagger-3">
          <div class="w-12 h-12 rounded-full bg-bg-secondary border-2 border-accent-cyan flex items-center justify-center font-display font-bold text-accent-cyan mb-4 shadow-lg shadow-accent-cyan/15 select-none">
            04
          </div>
          <h4 class="font-display font-semibold text-text-primary mb-2">Delivery</h4>
          <p class="font-body text-text-secondary text-sm leading-relaxed px-4">
            Clean code, documentation, and handoff
          </p>
        </div>

      </div>
    </div>

    <!-- CTA Banner -->
    <div class="bg-bg-surface border border-border-accent/40 rounded-2xl p-8 md:p-12 text-center max-w-4xl mx-auto shadow-xl relative overflow-hidden group reveal">
      <div class="absolute -right-16 -top-16 w-36 h-36 rounded-full bg-accent-cyan/5 blur-2xl group-hover:scale-125 transition-transform duration-500"></div>
      
      <div class="relative z-10 space-y-6">
        <h3 class="font-display font-bold text-2xl md:text-3xl text-text-primary">
          Ready to Start a Project?
        </h3>
        <p class="font-body text-text-secondary max-w-lg mx-auto text-base">
          I'm currently accepting freelance work. Let's talk about how I can bring your product to life.
        </p>
        <div class="pt-4">
          <a href="#contact" class="inline-flex items-center gap-2 px-8 py-3.5 rounded bg-accent-cyan text-bg-primary font-mono text-sm font-bold hover:shadow-lg hover:shadow-accent-cyan/20 hover:scale-[1.02] transition-all">
            Get In Touch &rarr;
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
