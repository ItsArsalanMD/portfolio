---
---

<section id="contact" class="py-24 relative overflow-hidden bg-bg-secondary/20">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Section Header -->
    <div class="mb-16 reveal">
      <span class="font-mono text-sm text-accent-cyan tracking-wider block mb-2">// CONTACT</span>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-text-primary">
        Let's Build Something
      </h2>
    </div>

    <!-- Main Contact Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Left Column: Info & Copy (5 columns equivalent) -->
      <div class="lg:col-span-5 space-y-8 reveal stagger-1">
        <p class="font-body text-text-secondary text-base md:text-lg leading-relaxed">
          Whether you're looking to hire a developer full-time, need a freelance engineer for your next project, or just want to talk tech — I'd love to hear from you.
        </p>

        <!-- Contact Details -->
        <div class="space-y-4 font-mono text-sm">
          <!-- Email -->
          <div class="flex items-center gap-3.5 group">
            <div class="w-10 h-10 rounded border border-border-main flex items-center justify-center text-accent-cyan group-hover:border-accent-cyan transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L22 8m-9 11h-3a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2h-3" />
              </svg>
            </div>
            <a href="mailto:mohammedarsalan204@gmail.com" class="text-text-secondary hover:text-accent-cyan transition-colors">
              mohammedarsalan204@gmail.com
            </a>
          </div>

          <!-- Phone -->
          <div class="flex items-center gap-3.5 group">
            <div class="w-10 h-10 rounded border border-border-main flex items-center justify-center text-accent-cyan group-hover:border-accent-cyan transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <a href="tel:+919422577039" class="text-text-secondary hover:text-accent-cyan transition-colors">
              +91 9422577039
            </a>
          </div>

          <!-- Location -->
          <div class="flex items-center gap-3.5 group">
            <div class="w-10 h-10 rounded border border-border-main flex items-center justify-center text-accent-cyan group-hover:border-accent-cyan transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <span class="text-text-secondary select-none">
              India
            </span>
          </div>
        </div>

        <!-- Social Profiles -->
        <div class="flex flex-wrap gap-4 font-mono text-xs">
          <!-- Github -->
          <a href="https://github.com/ItsArsalanMD" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2.5 rounded bg-bg-surface border border-border-main text-text-secondary hover:border-accent-cyan hover:text-accent-cyan transition-all hover:scale-[1.02] active:scale-98">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
            GitHub
          </a>
          
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/in/arsalan-shaikh-854546293/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2.5 rounded bg-bg-surface border border-border-main text-text-secondary hover:border-accent-cyan hover:text-accent-cyan transition-all hover:scale-[1.02] active:scale-98">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Right Column: Interactive Form (7 columns equivalent) -->
      <div class="lg:col-span-7 reveal stagger-2" id="form-container">
        <!-- Form -->
        <form id="contact-form" class="bg-bg-surface border border-border-main rounded-xl p-8 shadow-xl space-y-6" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <!-- Name -->
            <div class="flex flex-col space-y-2">
              <label for="name" class="font-mono text-xs uppercase tracking-wider text-text-secondary">Your Name</label>
              <input 
                type="text" 
                id="name" 
                name="name" 
                required 
                placeholder="John Doe"
                class="w-full bg-bg-secondary border border-border-main focus:border-accent-cyan focus:ring-1 focus:ring-accent-cyan/35 rounded-md px-4 py-3 text-text-primary text-sm font-body outline-none transition-all placeholder:text-text-muted"
              />
              <span class="error-msg font-mono text-[10px] text-red-400 hidden">Please enter your name.</span>
            </div>

            <!-- Email -->
            <div class="flex flex-col space-y-2">
              <label for="email" class="font-mono text-xs uppercase tracking-wider text-text-secondary">Email Address</label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required 
                placeholder="john@example.com"
                class="w-full bg-bg-secondary border border-border-main focus:border-accent-cyan focus:ring-1 focus:ring-accent-cyan/35 rounded-md px-4 py-3 text-text-primary text-sm font-body outline-none transition-all placeholder:text-text-muted"
              />
              <span class="error-msg font-mono text-[10px] text-red-400 hidden">Please enter a valid email.</span>
            </div>
          </div>

          <!-- Subject -->
          <div class="flex flex-col space-y-2">
            <label for="subject" class="font-mono text-xs uppercase tracking-wider text-text-secondary">Subject</label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              required 
              placeholder="Freelance Project Scoping"
              class="w-full bg-bg-secondary border border-border-main focus:border-accent-cyan focus:ring-1 focus:ring-accent-cyan/35 rounded-md px-4 py-3 text-text-primary text-sm font-body outline-none transition-all placeholder:text-text-muted"
            />
            <span class="error-msg font-mono text-[10px] text-red-400 hidden">Please specify a subject.</span>
          </div>

          <!-- Message -->
          <div class="flex flex-col space-y-2">
            <label for="message" class="font-mono text-xs uppercase tracking-wider text-text-secondary">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              required 
              placeholder="Hi Arsalan, I have an idea for a web app..."
              class="w-full bg-bg-secondary border border-border-main focus:border-accent-cyan focus:ring-1 focus:ring-accent-cyan/35 rounded-md px-4 py-3 text-text-primary text-sm font-body outline-none transition-all placeholder:text-text-muted resize-none"
            ></textarea>
            <span class="error-msg font-mono text-[10px] text-red-400 hidden">Please enter your message.</span>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="w-full py-3.5 rounded bg-accent-cyan text-bg-primary font-mono text-sm font-bold hover:shadow-lg hover:shadow-accent-cyan/20 active:scale-[0.99] transition-all duration-300"
          >
            Send Message &rarr;
          </button>
        </form>

        <!-- Success Message (Initially Hidden) -->
        <div id="success-card" class="bg-bg-surface border border-accent-green/35 rounded-xl p-8 shadow-xl text-center hidden flex flex-col items-center justify-center space-y-4 min-h-[300px]">
          <div class="w-16 h-16 rounded-full bg-accent-green/10 border border-accent-green/30 flex items-center justify-center text-accent-green">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-display font-bold text-2xl text-text-primary">
            Message Sent!
          </h3>
          <p class="font-body text-text-secondary max-w-sm">
            Thank you for reaching out. I have received your message and will get back to you soon.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContainer = document.getElementById('contact-form');
  const successCard = document.getElementById('success-card');

  if (form && successCard && formContainer) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      let isValid = true;
      const inputs = form.querySelectorAll('input[required], textarea[required]');
      
      inputs.forEach((input: any) => {
        const parent = input.parentElement;
        const errorMsg = parent.querySelector('.error-msg');
        
        // Custom error validation checking values
        let fieldValid = true;
        if (!input.value.trim()) {
          fieldValid = false;
        } else if (input.type === 'email') {
          // Simple email format check
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          fieldValid = emailRegex.test(input.value.trim());
        }

        if (!fieldValid) {
          isValid = false;
          input.classList.add('border-red-400', 'focus:border-red-400');
          input.classList.remove('focus:border-accent-cyan');
          errorMsg?.classList.remove('hidden');
        } else {
          input.classList.remove('border-red-400', 'focus:border-red-400');
          input.classList.add('focus:border-accent-cyan');
          errorMsg?.classList.add('hidden');
        }
      });

      if (isValid) {
        const nameVal = (form.querySelector('#name') as HTMLInputElement).value.trim();
        const emailVal = (form.querySelector('#email') as HTMLInputElement).value.trim();
        const subjectVal = (form.querySelector('#subject') as HTMLInputElement).value.trim();
        const messageVal = (form.querySelector('#message') as HTMLTextAreaElement).value.trim();

        const formattedText = `*New Contact Form Submission*\n\n*Name:* ${nameVal}\n*Email:* ${emailVal}\n*Subject:* ${subjectVal}\n*Message:* ${messageVal}`;
        const whatsappUrl = `https://wa.me/919422577039?text=${encodeURIComponent(formattedText)}`;

        // Mock successful submit by swapping elements with transition
        formContainer.classList.add('hidden');
        successCard.classList.remove('hidden');

        // Redirect/Open in WhatsApp
        window.open(whatsappUrl, '_blank');
        
        // Reset form
        form.reset();
      }
    });

    // Remove errors on input keypress
    const formFields = form.querySelectorAll('input, textarea');
    formFields.forEach((field) => {
      field.addEventListener('input', (e) => {
        const input = e.currentTarget as any;
        const parent = input.parentElement;
        const errorMsg = parent.querySelector('.error-msg');
        
        input.classList.remove('border-red-400', 'focus:border-red-400');
        input.classList.add('focus:border-accent-cyan');
        errorMsg?.classList.add('hidden');
      });
    });
  }
</script>
